#!/usr/bin/env python3
"""Manage named Codex and Claude credentials without copying secrets between hosts."""

from __future__ import annotations

import datetime as dt
import json
import os
from pathlib import Path
import re
import shutil
import subprocess
import sys
import time


HOME = Path.home()
ROOT = HOME / ".local" / "share" / "ai-accounts"
STATE = ROOT / "state"
SWITCHER = HOME / ".codex-switcher" / "accounts.json"
LABEL = re.compile(r"^[0-9A-Za-z][0-9A-Za-z._-]{0,63}$")
PROVIDERS = {"codex", "claude"}


def usage() -> None:
    print(
        """usage: ai-account login <codex|claude> <label>
       ai-account use <codex|claude> <label>
       ai-account remove <codex|claude> <label>
       ai-account run <codex|claude> <label> [arguments...]
       ai-account has <codex|claude> <label>
       ai-account current [codex|claude]
       ai-account list [codex|claude]
       ai-account import-stdin codex <label>

Selecting a profile affects newly launched processes immediately. Existing
Codex and Claude sessions continue with the account they started with.
Credentials are enrolled separately on every machine and are never synced.""",
        file=sys.stderr,
    )


def fail(message: str, code: int = 1) -> None:
    print(message, file=sys.stderr)
    raise SystemExit(code)


def check_provider(provider: str) -> None:
    if provider not in PROVIDERS:
        usage()
        raise SystemExit(2)


def check_label(label: str) -> None:
    if not LABEL.fullmatch(label):
        fail(f"Invalid account label: {label!r}", 2)


def initialize() -> None:
    for directory in (ROOT, STATE, ROOT / "codex", ROOT / "claude"):
        directory.mkdir(parents=True, exist_ok=True)
        directory.chmod(0o700)


def atomic_text(path: Path, value: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(f".{path.name}.tmp.{os.getpid()}")
    temporary.write_text(value, encoding="utf-8")
    temporary.chmod(0o600)
    os.replace(temporary, path)


def atomic_json(path: Path, value: object) -> None:
    atomic_text(path, json.dumps(value, indent=2) + "\n")


def now_ns() -> int:
    return time.time_ns()


def read_state(provider: str) -> tuple[str, int]:
    path = STATE / provider
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
        label = lines[0]
        changed = int(lines[1])
        check_label(label)
        return label, changed
    except (OSError, ValueError, IndexError):
        return "none", 0


def write_state(provider: str, label: str) -> int:
    changed = now_ns()
    atomic_text(STATE / provider, f"{label}\n{changed}\n")
    return changed


def codex_auth_is_valid(value: object) -> bool:
    if not isinstance(value, dict):
        return False
    if isinstance(value.get("OPENAI_API_KEY"), str) and value["OPENAI_API_KEY"]:
        return True
    tokens = value.get("tokens")
    required = {"id_token", "access_token", "refresh_token", "account_id"}
    return isinstance(tokens, dict) and all(isinstance(tokens.get(key), str) and tokens[key] for key in required)


def switcher_store() -> dict:
    try:
        value = json.loads(SWITCHER.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        fail(f"Could not read Codex Switcher accounts: {error}")
    if not isinstance(value, dict) or not isinstance(value.get("accounts"), list):
        fail("Codex Switcher accounts file has an unexpected format")
    return value


def switcher_account(label: str, store: dict | None = None) -> dict | None:
    store = store or switcher_store()
    matches = [item for item in store["accounts"] if isinstance(item, dict) and item.get("name") == label]
    if len(matches) > 1:
        fail(f"Codex Switcher has more than one account named {label!r}")
    return matches[0] if matches else None


def switcher_account_is_valid(account: dict | None) -> bool:
    if not account:
        return False
    data = account.get("auth_data")
    if not isinstance(data, dict):
        return False
    mode = data.get("type") or account.get("auth_mode")
    if mode == "api_key":
        return isinstance(data.get("api_key"), str) and bool(data["api_key"])
    required = {"id_token", "access_token", "refresh_token", "account_id"}
    return all(isinstance(data.get(key), str) and data[key] for key in required)


def switcher_current() -> tuple[str, int]:
    store = switcher_store()
    active = next((item for item in store["accounts"] if item.get("id") == store.get("active_account_id")), None)
    if not active:
        return "none", 0
    label = str(active.get("name", ""))
    check_label(label)
    raw = str(active.get("last_used_at") or "1970-01-01T00:00:00Z")
    try:
        changed = int(dt.datetime.fromisoformat(raw.replace("Z", "+00:00")).timestamp() * 1_000_000_000)
    except ValueError:
        changed = 0
    return label, changed


def switcher_use(label: str) -> None:
    store = switcher_store()
    account = switcher_account(label, store)
    if not switcher_account_is_valid(account):
        fail(f"Codex profile {label!r} is not enrolled in Codex Switcher on this Mac")
    assert account is not None
    data = account["auth_data"]
    mode = data.get("type") or account.get("auth_mode")
    if mode == "api_key":
        auth = {"OPENAI_API_KEY": data["api_key"]}
    else:
        auth = {
            "tokens": {key: data[key] for key in ("id_token", "access_token", "refresh_token", "account_id")},
            "last_refresh": dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z"),
        }
    account["last_used_at"] = dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z")
    store["active_account_id"] = account["id"]
    atomic_json(HOME / ".codex" / "auth.json", auth)
    atomic_json(SWITCHER, store)
    write_state("codex", label)


def profile_dir(provider: str, label: str) -> Path:
    return ROOT / provider / label


def has_profile(provider: str, label: str) -> bool:
    if provider == "codex":
        if SWITCHER.exists():
            return switcher_account_is_valid(switcher_account(label))
        path = profile_dir("codex", label) / "auth.json"
        try:
            return codex_auth_is_valid(json.loads(path.read_text(encoding="utf-8")))
        except (OSError, json.JSONDecodeError):
            return False
    return (profile_dir("claude", label) / ".ai-account-enrolled").is_file()


def current(provider: str) -> tuple[str, int]:
    if provider == "codex" and SWITCHER.exists():
        return switcher_current()
    return read_state(provider)


def executable(provider: str) -> Path:
    wrapper = HOME / ".local" / "account-bin" / provider
    if wrapper.is_file():
        return wrapper
    fallback = HOME / ".local" / "bin" / provider
    if fallback.exists():
        return fallback
    found = shutil.which(provider)
    if found:
        return Path(found)
    fail(f"Could not find the {provider} executable")


def use(provider: str, label: str) -> None:
    if not has_profile(provider, label):
        fail(f"{provider.capitalize()} profile {label!r} is not enrolled on this machine")
    if provider == "codex" and SWITCHER.exists():
        switcher_use(label)
    else:
        write_state(provider, label)
    print(f"Selected {provider} profile {label} for new sessions; running sessions are unchanged.")


def login(provider: str, label: str) -> None:
    if provider == "codex" and SWITCHER.exists():
        fail("Add the account in Codex Switcher on this Mac, give it the desired label, then select it once.")
    directory = profile_dir(provider, label)
    directory.mkdir(parents=True, exist_ok=True)
    directory.chmod(0o700)
    env = os.environ.copy()
    if provider == "codex":
        env["CODEX_ACCOUNT"] = label
        command = [str(executable("codex")), "login", "--device-auth"]
    else:
        env["CLAUDE_ACCOUNT"] = label
        command = [str(executable("claude")), "auth", "login", "--claudeai"]
    result = subprocess.run(command, env=env)
    if result.returncode:
        fail(f"{provider.capitalize()} login did not complete")
    if provider == "codex":
        if not has_profile(provider, label):
            fail("Codex login did not create a usable profile")
    else:
        status = subprocess.run(
            [str(executable("claude")), "auth", "status"],
            env=env,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
        )
        try:
            status_value = json.loads(status.stdout)
        except json.JSONDecodeError:
            status_value = {}
        if status.returncode or not status_value.get("loggedIn"):
            fail("Claude login finished without a usable authenticated profile")
        atomic_text(directory / ".ai-account-enrolled", f"{now_ns()}\n")
    write_state(provider, label)
    print(f"Saved and selected {provider} profile {label}.")


def remove(provider: str, label: str) -> None:
    selected, _ = current(provider)
    if selected == label:
        fail(f"Select another {provider} profile before removing {label!r}")
    if provider == "codex" and SWITCHER.exists():
        fail("Remove this account with Codex Switcher on the Mac; it owns the Mac credential list.")
    directory = profile_dir(provider, label)
    if not directory.is_dir():
        fail(f"{provider.capitalize()} profile {label!r} does not exist on this machine")
    if provider == "claude" and has_profile(provider, label):
        env = os.environ.copy()
        env["CLAUDE_ACCOUNT"] = label
        subprocess.run([str(executable("claude")), "auth", "logout"], env=env, check=False)
    if directory.parent != ROOT / provider:
        fail("Refusing to remove an unexpected profile path")
    shutil.rmtree(directory)
    print(f"Removed {provider} profile {label} from this machine.")


def list_profiles(provider: str) -> None:
    if provider == "codex" and SWITCHER.exists():
        labels = sorted(
            str(item["name"])
            for item in switcher_store()["accounts"]
            if isinstance(item, dict) and isinstance(item.get("name"), str) and switcher_account_is_valid(item)
        )
    else:
        base = ROOT / provider
        labels = sorted(path.name for path in base.iterdir() if path.is_dir() and has_profile(provider, path.name))
    selected, _ = current(provider)
    rendered = [f"{label}{'*' if label == selected else ''}" for label in labels]
    print(f"{provider}: {' '.join(rendered) if rendered else '(none)'}")


def import_codex(label: str) -> None:
    if SWITCHER.exists():
        fail("Codex Switcher owns Codex credentials on this Mac")
    data = sys.stdin.buffer.read()
    try:
        value = json.loads(data)
    except json.JSONDecodeError:
        fail("Imported credential is not valid JSON")
    if not codex_auth_is_valid(value):
        fail("Imported credential did not match the Codex auth format")
    directory = profile_dir("codex", label)
    directory.mkdir(parents=True, exist_ok=True)
    directory.chmod(0o700)
    atomic_text(directory / "auth.json", json.dumps(value, indent=2) + "\n")
    print(f"Imported codex profile {label}.")


def run_profile(provider: str, label: str, arguments: list[str]) -> None:
    if not has_profile(provider, label):
        fail(f"{provider.capitalize()} profile {label!r} is not enrolled on this machine")
    env_name = "CODEX_ACCOUNT" if provider == "codex" else "CLAUDE_ACCOUNT"
    os.environ[env_name] = label
    os.execv(str(executable(provider)), [provider, *arguments])


def main(arguments: list[str]) -> int:
    initialize()
    if not arguments:
        usage()
        return 2
    command = arguments[0]
    if command in {"login", "use", "request", "remove", "has"}:
        if len(arguments) != 3:
            usage()
            return 2
        provider, label = arguments[1:]
        check_provider(provider)
        check_label(label)
        if command == "login":
            login(provider, label)
        elif command in {"use", "request"}:
            use(provider, label)
        elif command == "remove":
            remove(provider, label)
        else:
            return 0 if has_profile(provider, label) else 1
        return 0
    if command == "run":
        if len(arguments) < 3:
            usage()
            return 2
        provider, label = arguments[1:3]
        check_provider(provider)
        check_label(label)
        run_profile(provider, label, arguments[3:])
    if command == "current":
        providers = [arguments[1]] if len(arguments) == 2 else ["codex", "claude"]
        if len(arguments) > 2:
            usage()
            return 2
        for provider in providers:
            check_provider(provider)
            label, changed = current(provider)
            print(f"{provider}={label}\n{provider}_updated={changed}")
        return 0
    if command == "list":
        providers = [arguments[1]] if len(arguments) == 2 else ["codex", "claude"]
        if len(arguments) > 2:
            usage()
            return 2
        for provider in providers:
            check_provider(provider)
            list_profiles(provider)
        return 0
    if command == "import-stdin" and len(arguments) == 3 and arguments[1] == "codex":
        check_label(arguments[2])
        import_codex(arguments[2])
        return 0
    usage()
    return 2


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv[1:]))
    except KeyboardInterrupt:
        raise SystemExit(130)
