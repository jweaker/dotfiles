#!/bin/sh
set -eu

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  echo 'usage: a1-port <remote-port> [local-port]' >&2
  exit 2
fi
remote_port="$1"
local_port="${2:-$1}"
case "$remote_port:$local_port" in
  *[!0-9:]*|:|*:|:*) echo 'Ports must be numbers.' >&2; exit 2 ;;
esac
if [ "$remote_port" -lt 1 ] || [ "$remote_port" -gt 65535 ] || [ "$local_port" -lt 1 ] || [ "$local_port" -gt 65535 ]; then
  echo 'Ports must be between 1 and 65535.' >&2
  exit 2
fi
printf 'Forwarding http://127.0.0.1:%s to A1 port %s. Press Ctrl-C to stop.\n' "$local_port" "$remote_port"
exec /usr/bin/ssh -NT -o ExitOnForwardFailure=yes \
  -L "127.0.0.1:${local_port}:127.0.0.1:${remote_port}" a1
