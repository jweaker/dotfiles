#!/usr/bin/env python3
"""Make new A1 Codex sessions follow the Mac Codex Switcher label."""

from __future__ import annotations

import datetime as dt
import json
import os
from pathlib import Path
import re
import subprocess
import sys

HOME = Path.home()
SWITCHER = HOME / ".codex-switcher" / "accounts.json"
STATE_DIR = HOME / "Library" / "Application Support" / "A1 Workstation"
STATE = STATE_DIR / "codex-account-sync.json"
LABEL = re.compile(r"^[0-9A-Za-z][0-9A-Za-z._-]{0,63}$")


def atomic_json(path: Path, value: object) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(f".{path.name}.tmp.{os.getpid()}")
    with temporary.open("w", encoding="utf-8") as handle:
        json.dump(value, handle, indent=2)
        handle.write("\n")
    os.chmod(temporary, 0o600)
    os.replace(temporary, path)


def mac_account() -> tuple[str, float, dict, dict]:
    store = json.loads(SWITCHER.read_text(encoding="utf-8"))
    active_id = store.get("active_account_id")
    account = next((item for item in store.get("accounts", []) if item.get("id") == active_id), None)
    if not account:
        raise RuntimeError("Codex Switcher has no active account")
    label = str(account.get("name", ""))
    if not LABEL.fullmatch(label):
        raise RuntimeError(f"Unexpected Codex account label: {label!r}")
    raw_time = account.get("last_used_at") or "1970-01-01T00:00:00Z"
    when = dt.datetime.fromisoformat(str(raw_time).replace("Z", "+00:00")).timestamp()
    return label, when, store, account


def remote_account() -> tuple[str, float]:
    result = subprocess.run(
        ["/usr/bin/ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=8", "a1", "~/.local/bin/ai-account current codex"],
        check=True,
        text=True,
        capture_output=True,
        timeout=15,
    )
    values = dict(line.split("=", 1) for line in result.stdout.splitlines() if "=" in line)
    label = values.get("codex", "none")
    changed = float(values.get("codex_updated", "0"))
    if label != "none" and not LABEL.fullmatch(label):
        raise RuntimeError("A1 returned an invalid Codex account label")
    return label, changed


def select_on_a1(label: str) -> None:
    subprocess.run(
        ["/usr/bin/ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=8", "a1", f"~/.local/bin/ai-account use codex '{label}'"],
        check=True,
        timeout=15,
    )


def main() -> int:
    if not SWITCHER.exists():
        return 0
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    local, _, _, _ = mac_account()
    remote, _ = remote_account()
    if local != remote:
        select_on_a1(local)
        remote = local
    atomic_json(STATE, {"local": local, "remote": remote})
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except (OSError, RuntimeError, subprocess.SubprocessError, json.JSONDecodeError) as error:
        print(f"[a1-codex-account-sync] {error}", file=sys.stderr)
        raise SystemExit(1)
