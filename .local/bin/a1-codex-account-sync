#!/usr/bin/env python3
"""Synchronize Codex account labels without moving credentials between machines."""

from __future__ import annotations

import datetime as dt
import json
import os
from pathlib import Path
import re
import subprocess
import sys

HOME = Path.home()
SWITCHER = HOME / ".codex-switcher" / "accounts.json"
AUTH = HOME / ".codex" / "auth.json"
STATE_DIR = HOME / "Library" / "Application Support" / "A1 Workstation"
STATE = STATE_DIR / "codex-account-sync.json"
LABEL = re.compile(r"^[0-9A-Za-z][0-9A-Za-z._-]{0,63}$")


def atomic_json(path: Path, value: object) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(f".{path.name}.tmp.{os.getpid()}")
    with temporary.open("w", encoding="utf-8") as handle:
        json.dump(value, handle, indent=2)
        handle.write("\n")
    os.chmod(temporary, 0o600)
    os.replace(temporary, path)


def mac_account() -> tuple[str, float, dict, dict]:
    store = json.loads(SWITCHER.read_text(encoding="utf-8"))
    active_id = store.get("active_account_id")
    account = next((item for item in store.get("accounts", []) if item.get("id") == active_id), None)
    if not account:
        raise RuntimeError("Codex Switcher has no active account")
    label = str(account.get("name", ""))
    if not LABEL.fullmatch(label):
        raise RuntimeError(f"Unexpected Codex account label: {label!r}")
    raw_time = account.get("last_used_at") or "1970-01-01T00:00:00Z"
    when = dt.datetime.fromisoformat(str(raw_time).replace("Z", "+00:00")).timestamp()
    return label, when, store, account


def remote_account() -> tuple[str, float]:
    result = subprocess.run(
        ["/usr/bin/ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=8", "a1", "~/.local/bin/ai-account current codex"],
        check=True,
        text=True,
        capture_output=True,
        timeout=15,
    )
    values = dict(line.split("=", 1) for line in result.stdout.splitlines() if "=" in line)
    label = values.get("codex", "none")
    changed = float(values.get("codex_updated", "0"))
    if label != "none" and not LABEL.fullmatch(label):
        raise RuntimeError("A1 returned an invalid Codex account label")
    return label, changed


def codex_busy() -> bool:
    checks = (["/usr/bin/pgrep", "-x", "codex"], ["/usr/bin/pgrep", "-f", "/Applications/Codex.app/"])
    return any(subprocess.run(check, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0 for check in checks)


def select_on_mac(label: str, store: dict) -> None:
    if codex_busy():
        raise RuntimeError("Codex is running; remote selection remains queued")
    account = next((item for item in store.get("accounts", []) if item.get("name") == label), None)
    if not account:
        raise RuntimeError(f"Mac Codex Switcher has no profile named {label!r}")
    data = account.get("auth_data") or {}
    mode = data.get("type") or account.get("auth_mode")
    if mode == "chat_g_p_t":
        required = ("id_token", "access_token", "refresh_token", "account_id")
        if any(not data.get(key) for key in required):
            raise RuntimeError(f"Codex profile {label!r} has incomplete ChatGPT credentials")
        auth = {"tokens": {key: data[key] for key in required}, "last_refresh": dt.datetime.now(dt.timezone.utc).isoformat()}
    elif mode == "api_key" and data.get("api_key"):
        auth = {"OPENAI_API_KEY": data["api_key"]}
    else:
        raise RuntimeError(f"Unsupported Codex authentication mode for {label!r}")
    atomic_json(AUTH, auth)
    now = dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z")
    store["active_account_id"] = account["id"]
    account["last_used_at"] = now
    atomic_json(SWITCHER, store)


def select_on_a1(label: str) -> None:
    subprocess.run(
        ["/usr/bin/ssh", "-o", "BatchMode=yes", "-o", "ConnectTimeout=8", "a1", f"~/.local/bin/ai-account request codex '{label}'"],
        check=True,
        timeout=15,
    )


def main() -> int:
    if not SWITCHER.exists():
        return 0
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    local, local_time, store, _ = mac_account()
    remote, remote_time = remote_account()
    if not STATE.exists():
        atomic_json(STATE, {"local": local, "remote": remote})
        return 0
    previous = json.loads(STATE.read_text(encoding="utf-8"))
    local_changed = local != previous.get("local")
    remote_changed = remote != previous.get("remote")
    if remote == "none":
        atomic_json(STATE, {"local": local, "remote": remote})
        return 0
    if local_changed and (not remote_changed or local_time >= remote_time):
        select_on_a1(local)
        remote = local
    elif remote_changed:
        select_on_mac(remote, store)
        local = remote
    atomic_json(STATE, {"local": local, "remote": remote})
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except (OSError, RuntimeError, subprocess.SubprocessError, json.JSONDecodeError) as error:
        print(f"[a1-codex-account-sync] {error}", file=sys.stderr)
        raise SystemExit(1)
