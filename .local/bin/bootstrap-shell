#!/usr/bin/env bash
set -Eeuo pipefail

zsh_root=${ZSH:-"$HOME/.zsh"}
install -d -m 755 "$zsh_root/plugins" "$zsh_root/themes"

clone_if_missing() {
  local repository=$1
  local destination=$2
  if [[ ! -d "$destination/.git" ]]; then
    git clone --depth=1 "$repository" "$destination"
  fi
}

clone_if_missing https://github.com/romkatv/powerlevel10k.git \
  "$zsh_root/themes/powerlevel10k"

# Keep Powerlevel10k current when the managed checkout has no local edits.
# This avoids running stale prompt code against newer Zsh releases.
p10k_root="$zsh_root/themes/powerlevel10k"
if git -C "$p10k_root" diff --quiet && \
   git -C "$p10k_root" diff --cached --quiet; then
  if [[ -f "$p10k_root/.git/shallow" ]]; then
    git -C "$p10k_root" fetch --unshallow origin master
  else
    git -C "$p10k_root" fetch origin master
  fi
  git -C "$p10k_root" merge --ff-only origin/master
else
  printf 'Powerlevel10k has local edits; leaving it unchanged.\n' >&2
fi

clone_if_missing https://github.com/Aloxaf/fzf-tab.git \
  "$zsh_root/plugins/fzf-tab"
clone_if_missing https://github.com/zsh-users/zsh-autosuggestions.git \
  "$zsh_root/plugins/zsh-autosuggestions"
clone_if_missing https://github.com/zsh-users/zsh-syntax-highlighting.git \
  "$zsh_root/plugins/zsh-syntax-highlighting"
clone_if_missing https://github.com/zsh-users/zsh-completions.git \
  "$zsh_root/plugins/zsh-completions"

install -d -m 755 "$zsh_root/plugins/omz"
if [[ ! -f "$zsh_root/plugins/omz/sudo.plugin.zsh" ]]; then
  curl -fsSL \
    https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/plugins/sudo/sudo.plugin.zsh \
    -o "$zsh_root/plugins/omz/sudo.plugin.zsh"
fi

touch "$zsh_root/P10K"
echo "Shell dependencies are installed under $zsh_root."
