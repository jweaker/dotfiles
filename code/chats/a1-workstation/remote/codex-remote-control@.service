[Unit]
Description=Codex Remote Control (%i account)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=CODEX_ACCOUNT=%i
Environment=PATH=%h/.local/bin:%h/.local/share/mise/shims:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/codex remote-control start --json
ExecStop=%h/.local/bin/codex remote-control stop --json
RemainAfterExit=yes
TimeoutStartSec=30
TimeoutStopSec=15
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
